# Application environment
APP_ENV=development
LOG_LEVEL=INFO

# Backend selection (all default to the free local stack)
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=local
VECTOR_BACKEND=chroma
STORAGE_BACKEND=local
MEMORY_BACKEND=memory

# LLM: Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LLM: Bedrock (pay-per-token, zero idle cost; used when LLM_PROVIDER=bedrock)
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# Optional Bedrock Guardrails identifier and version
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Generation parameters
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=800

# Embeddings: local Sentence Transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
# Must match the active embedding provider: 384 for all-MiniLM-L6-v2, 1024 for Titan v2
EMBEDDING_DIM=384

# Vector store: Chroma (local)
VECTOR_DB_PATH=./data/vector_db
CHROMA_COLLECTION_NAME=rag_documents

# Vector store: OpenSearch (open-source Docker image locally; used when VECTOR_BACKEND=opensearch)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=rag_documents
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false

# Retrieval and chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=6

# AWS general (set AWS_ENDPOINT_URL=http://localhost:4566 to target LocalStack)
AWS_REGION=eu-central-1
AWS_ENDPOINT_URL=
S3_BUCKET=aiagentlab-documents
DYNAMODB_TABLE=aiagentlab-state

# Agent orchestration
AGENT_MAX_STEPS=6
ESCALATION_CONFIDENCE_THRESHOLD=0.45

# Optional Hugging Face token for gated embedding models
HF_TOKEN=
