# Application environment
APP_ENV=development
LOG_LEVEL=INFO

# LLM provider
GROQ_API_KEY=your_groq_api_key_here

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector store
VECTOR_DB_PATH=./data/vector_db
CHROMA_COLLECTION_NAME=rag_documents

# Retrieval
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=6

# Optional
HF_TOKEN=